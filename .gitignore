# ─── Dependencies ────────────────────────────────────────────────
node_modules/

# ─── Build output ────────────────────────────────────────────────
# lib/ is generated by `bob build` on publish — never commit it.
lib/

# ─── Logs ────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ─── Test / coverage ─────────────────────────────────────────────
coverage/

# ─── Caches & build metadata ─────────────────────────────────────
.cache/
.metro-health-check*
.eslintcache
*.tsbuildinfo

# ─── Package tarballs ────────────────────────────────────────────
*.tgz

# ─── OS files ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ─── Editors / IDEs ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Environment / secrets ───────────────────────────────────────
.env
.env.*
!.env.example

# ─── Misc / stray Windows artifacts ──────────────────────────────
*.orig
nul

# NOTE: the example app has its own example/.gitignore that handles all
# of its native (android/ios) and Metro build artifacts.
